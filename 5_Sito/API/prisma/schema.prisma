generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model audio {
  id             Int           @id @default(autoincrement())
  audio_url      String?       @db.VarChar(255)
  description_id Int?
  descriptions   descriptions? @relation(fields: [description_id], references: [id], onDelete: Cascade, map: "audio_ibfk_1")

  @@index([description_id], map: "description_id")
}

model classrooms {
  id         Int        @id @default(autoincrement())
  class_num  Int?
  isDoorOpen Int?       @db.TinyInt
  npcs       npcs[]
  posters    posters[]
  quizzes    quizzes[]
  subjects   subjects[]
}

model descriptions {
  id          Int       @id @default(autoincrement())
  description String?   @db.Text
  audio       audio[]
  npcs        npcs[]
  posters     posters[]
}

model npcs {
  id             Int           @id @default(autoincrement())
  class_id       Int?
  description_id Int?
  classrooms     classrooms?   @relation(fields: [class_id], references: [id], onDelete: Cascade, map: "npcs_ibfk_1")
  descriptions   descriptions? @relation(fields: [description_id], references: [id], onDelete: Cascade, map: "npcs_ibfk_2")

  @@index([class_id], map: "class_id")
  @@index([description_id], map: "description_id")
}

model posters {
  id             Int           @id @default(autoincrement())
  image_url      String?       @db.VarChar(255)
  class_id       Int?
  description_id Int?
  classrooms     classrooms?   @relation(fields: [class_id], references: [id], onDelete: Cascade, map: "posters_ibfk_1")
  descriptions   descriptions? @relation(fields: [description_id], references: [id], onDelete: Cascade, map: "posters_ibfk_2")

  @@index([class_id], map: "class_id")
  @@index([description_id], map: "description_id")
}

model statistics {
  id                       Int       @id @default(autoincrement())
  developer_percent        Float?    @db.Float
  system_engineers_percent Float?    @db.Float
  daily_player             Int?
  classroom_visited        Int?
  visiting_time            DateTime? @db.Time(0)
  subject_id               Int?
  created_at               DateTime? @default(now()) @db.DateTime(0)
  subjects                 subjects? @relation(fields: [subject_id], references: [id], onDelete: Cascade, map: "statistics_ibfk_1")

  @@index([subject_id], map: "subject_id")
}

model subjects {
  id         Int          @id @default(autoincrement())
  name       String?      @db.VarChar(255)
  class_id   Int?
  statistics statistics[]
  classrooms classrooms?  @relation(fields: [class_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "subjects_ibfk_1")

  @@index([class_id], map: "subjects_ibfk_1")
}

model quizzes {
  id         Int         @id @default(autoincrement())
  question   String?     @db.VarChar(255)
  answer     String?     @db.VarChar(255)
  class_id   Int?
  classrooms classrooms? @relation(fields: [class_id], references: [id], onDelete: Cascade, map: "quizzes_ibfk_1")

  @@index([class_id], map: "class_id")
}
